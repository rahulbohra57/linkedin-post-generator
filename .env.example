# ============================================================
# LinkedIn Post Generator — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ------ LLMs ------
# Which LLM to use for creative tasks: "gemini" (default) or "claude"
# Use "gemini" if you don't have Anthropic credits — GEMINI_API_KEY is enough to run the full app.
PRIMARY_LLM=gemini

# Primary LLM (creative writing, reasoning) — only needed if PRIMARY_LLM=claude
ANTHROPIC_API_KEY=sk-ant-...

# Fast LLM (classification, formatting) — already in your .env
GEMINI_API_KEY=AIza...

# Image generation via DALL-E 3
OPENAI_API_KEY=sk-...

# Fallback LLM (optional, kept for reference)
HUGGINGFACEHUB_API_TOKEN=hf_...

# ------ Search & Images ------
# Web research for agents — already in your .env
TAVILY_API_KEY=tvly-...

# Stock photo search — free tier at pexels.com/api
PEXELS_API_KEY=...

# ------ LinkedIn OAuth ------
# Create app at: https://developer.linkedin.com/
# Request: w_member_social, r_liteprofile, r_emailaddress scopes
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/auth/linkedin/callback

# ------ Infrastructure ------
DATABASE_URL=sqlite+aiosqlite:///./linkedin_posts.db
REDIS_URL=redis://localhost:6379/0

# ------ Storage ------
LOCAL_STORAGE_PATH=./storage/images

# ------ App ------
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000
